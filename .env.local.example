# ─── Supabase ────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─── DataforSEO ───────────────────────────────────────────────
DATAFORSEO_LOGIN=your-login@email.com
DATAFORSEO_PASSWORD=your-api-password

# ─── Google APIs ──────────────────────────────────────────────
GOOGLE_PLACES_API_KEY=your-google-places-api-key
# GOOGLE_MAPS_API_KEY is only needed if you add Maps Embed features later
# GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# ─── Anthropic Claude ─────────────────────────────────────────
ANTHROPIC_API_KEY=your-anthropic-api-key
# Optional: override defaults (Railway: set API key; if primary model ID is unavailable, set a fallback)
# ANTHROPIC_MODEL=claude-sonnet-4-6
# ANTHROPIC_MODEL_FALLBACK=claude-haiku-4-5-20251001

# ─── SendGrid ─────────────────────────────────────────────────
SENDGRID_API_KEY=your-sendgrid-api-key
SENDGRID_FROM_EMAIL=hello@serpmap.com.au
# Create 3 transactional templates in SendGrid and paste the d-xxxx IDs here
SENDGRID_TEMPLATE_CONFIRMATION=d-your-template-id
SENDGRID_TEMPLATE_DAY3=d-your-template-id
SENDGRID_TEMPLATE_DAY7=d-your-template-id

# ─── Lead CTA ─────────────────────────────────────────────────
# Where the "Fix your invisible zones" CTA button points.
# Currently: DotMappers waitlist page.
# On product launch day: change to https://app.[product].com.au/trial
# This is the ONLY change needed to activate full product conversion tracking.
LEAD_CTA_BASE_URL=https://dotmappers.in/waitlist
NEXT_PUBLIC_LEAD_CTA_BASE_URL=https://dotmappers.in/waitlist

# ─── Webhook Auth ─────────────────────────────────────────────
# Shared secret for /api/webhooks/conversion
# Set the same value in any future product that calls this endpoint
WEBHOOK_SECRET=generate-a-random-32-char-secret-here

# ─── Waitlist nav link ────────────────────────────────────────
NEXT_PUBLIC_WAITLIST_URL=https://dotmappers.in/waitlist

# ─── App ──────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://serpmap.com.au
DAILY_REPORT_QUOTA=200
